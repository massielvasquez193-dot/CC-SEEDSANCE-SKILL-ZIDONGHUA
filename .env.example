# ============================================================
# TikTok AI Video Factory — 环境变量配置
# 复制此文件为 .env 并填入你的API密钥
#   cp .env.example .env
# ============================================================

# --- 默认AI提供商 (openai / claude / deepseek / gemini) ---
TIKTOK_FACTORY_AI_PROVIDER=claude

# ============================================================
# AI Provider — API Keys
# ============================================================

# OpenAI (GPT-4o / DALL-E 3)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude (Sonnet / Opus / Haiku)
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# DeepSeek (Chat / Reasoner)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini (Flash / Pro)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Video Generation Platforms (optional)
# ============================================================

# Seedance (图生视频 / 分段生成)
SEEDANCE_API_KEY=your-seedance-key

# Google VEO3 (完整视频生成 8s/15s/30s/60s)
VEO3_API_KEY=your-veo3-key

# 即梦 Jimeng (字节跳动 — 文生视频/图生视频)
JIMENG_API_KEY=your-jimeng-key

# Runway Gen-3/4 (图生视频 / 导演模式)
RUNWAY_API_KEY=your-runway-key

# 可灵 Kling (快手 — 图生视频 / 运镜控制)
KLING_API_KEY=your-kling-key

# ============================================================
# Factory Settings
# ============================================================

# 目标国家 (US/GB/ID/BR/TH/VN/PH/MX/JP/KR/SA/AE/CN)
TIKTOK_FACTORY_COUNTRY=US

# 输出语言 (en/id/pt/th/vi/es/ja/ko/ar/zh)
TIKTOK_FACTORY_LANGUAGE=en

# 视频时长 (8/15/30/60)
TIKTOK_FACTORY_VIDEO_DURATION=15

# 每次运行输出数量
TIKTOK_FACTORY_OUTPUT_COUNT=1

# 任务配对模式 (cartesian / one_to_one)
TIKTOK_FACTORY_PAIRING_MODE=one_to_one

# 最大并发任务数
TIKTOK_FACTORY_MAX_CONCURRENT=3

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
TIKTOK_FACTORY_LOG_LEVEL=INFO
